# Node.js gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# PM2 logs
.pm2/

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Uploads
uploads/*
!uploads/.gitkeep

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Backups
*.bak
*.backup

# Database
*.sql
backups/
