# ============================================================================
# LIFEWAY COMPUTERS - RENDER.COM DEPLOYMENT CONFIGURATION
# ============================================================================
# Instructions:
# 1. Copy this file to .env
# 2. Fill in the actual values for your Hostinger MySQL database
# 3. Generate a strong JWT_SECRET (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# 4. Add to Render.com environment variables in your service settings
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# Hostinger MySQL Database Configuration
# ============================================================================
# IMPORTANT: You'll need to whitelist Render's IP addresses in Hostinger's firewall
# Visit Hostinger cPanel → Remote MySQL → Add IP Address (leave blank for all)

# MySQL Host - Get this from Hostinger cPanel > Databases > Remote MySQL
# Format: mysql.hostinger.com or your_cpanel_username.mysql.net
DB_HOST=your-hostinger-mysql-host.com

# MySQL Port (usually 3306)
DB_PORT=3306

# Database Username - Get this from Hostinger cPanel > MySQL Databases
DB_USER=your_database_user

# Database Password - Get this from Hostinger cPanel > MySQL Databases
DB_PASSWORD=your_database_password

# Database Name - Get this from Hostinger cPanel > MySQL Databases
DB_NAME=your_database_name

# ============================================================================
# Database Connection Pool Configuration (Optimized for Render)
# ============================================================================
# Wait for connections to be available
DB_WAIT_FOR_CONNECTIONS=true

# Maximum number of connections
DB_CONNECTION_LIMIT=10

# Maximum number of connection requests the pool will queue
DB_QUEUE_LIMIT=0

# Enable Keep-Alive for persistent connections
DB_ENABLE_KEEP_ALIVE=true

# Initial delay before keep-alive probe
DB_KEEP_ALIVE_INITIAL_DELAY_MS=0

# ============================================================================
# Frontend Configuration (Your Hostinger-hosted frontend)
# ============================================================================
# Primary Frontend URL
FRONTEND_URL=https://your-hostinger-domain.com

# Multiple Frontend URLs (comma-separated for CORS)
# Include both production and localhost for development
FRONTEND_URLS=https://your-hostinger-domain.com,http://localhost:3000,http://localhost:5000

# ============================================================================
# JWT Authentication
# ============================================================================
# IMPORTANT: Generate a secure secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_generate_a_random_string

# JWT Token Expiration
JWT_EXPIRE=7d

# ============================================================================
# Session Configuration
# ============================================================================
SESSION_SECRET=your_session_secret_key_change_this_in_production_generate_a_random_string

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file size in bytes (10 MB)
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=./uploads

# ============================================================================
# CORS Settings
# ============================================================================
# CORS Origin (your Hostinger domain)
CORS_ORIGIN=https://your-hostinger-domain.com

# Enable credentials in CORS
CORS_CREDENTIALS=true

